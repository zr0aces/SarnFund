# SEC Open Data API Subscription Keys
# Developer portal: https://secopendata.sec.or.th/sec-open-apis
# (Old portal api-portal.sec.or.th is discontinued as of June 30, 2026)
#
# Steps:
#   1. Sign up / Sign in at secopendata.sec.or.th/sec-open-apis
#   2. Go to Products → Subscribe to "Fund Factsheet API"
#   3. Go to Products → Subscribe to "Fund Daily Info API"
#   4. Each subscription provides a Primary Key and a Secondary Key.
#      Copy both from the subscription detail page.
#
# Primary keys are used for every request.
# Secondary keys are used automatically if the primary returns 401
# (zero-downtime key rotation — revoke primary, promote secondary, set new secondary).
#
# Rate limit: 3,000 calls per 300 seconds per key.

# Fund Factsheet API
SEC_FACTSHEET_KEY=your_factsheet_primary_key_here
SEC_FACTSHEET_KEY_2=your_factsheet_secondary_key_here

# Fund Daily Info API
SEC_DAILYINFO_KEY=your_dailyinfo_primary_key_here
SEC_DAILYINFO_KEY_2=your_dailyinfo_secondary_key_here

# Random secret to protect the manual-scrape endpoint (POST /api/scrape)
# Pass via: X-Scrape-Token header or ?token= query param
SCRAPE_TOKEN=change_me_to_a_random_secret

# Optional: restrict CORS in production
# CORS_ORIGIN=https://yourdomain.com

# Optional: override default port (3001)
# PORT=3001
