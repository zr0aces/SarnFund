# SEC Open Data API Subscription Keys
# Register and subscribe at: https://secopendata.sec.or.th/sec-open-apis
#
# Steps:
#   1. Sign up / Sign in at secopendata.sec.or.th/sec-open-apis
#   2. Go to Products → Subscribe to "Fund Factsheet API"
#   3. Go to Products → Subscribe to "Fund Daily Info API"
#   4. Copy the generated Subscription Key for each product below.
#
# Rate limit: 3,000 calls per 300 seconds per key.

SEC_FACTSHEET_KEY=your_fund_factsheet_subscription_key_here
SEC_DAILYINFO_KEY=your_fund_daily_info_subscription_key_here

# Random secret to protect the manual-scrape endpoint (POST /api/scrape)
# Pass via: X-Scrape-Token header or ?token= query param
SCRAPE_TOKEN=change_me_to_a_random_secret

# Optional: restrict CORS in production
# CORS_ORIGIN=https://yourdomain.com

# Optional: override default port (3001)
# PORT=3001
