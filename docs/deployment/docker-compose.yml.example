services:
  backend:
    container_name: sarnfund-backend
    image: ghcr.io/your-username/sarnfund-backend:${APP_VERSION:-latest}
    volumes:
      - ./data:/app/data
    env_file:
      - ./.env
    environment:
      - PORT=3001
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:3001/api/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s

  frontend:
    container_name: sarnfund-frontend-builder
    image: ghcr.io/your-username/sarnfund-frontend-builder:${APP_VERSION:-latest}
    command: sh -c "cp -r /app/dist/. /app/html/"
    volumes:
      - frontend_dist:/app/html
    restart: "no"

  nginx:
    container_name: sarnfund-nginx
    image: nginx:alpine
    ports:
      - "8091:80"
    volumes:
      - ./nginx/default.conf:/etc/nginx/conf.d/default.conf:ro
      - frontend_dist:/usr/share/nginx/html:ro
    depends_on:
      frontend:
        condition: service_completed_successfully
      backend:
        condition: service_started
    restart: unless-stopped

volumes:
  frontend_dist:
  backend_data:
